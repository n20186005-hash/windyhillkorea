    principles: [
      { id: 'deck', label: '木道と既存の歩道から外れない' },
      { id: 'trash', label: 'ごみを草地や海辺に残さない' },
      { id: 'quiet', label: '騒音を抑え、柵を越えて撮影しない' },
    ],
  },
  ko: {
    title: '현장 과학 카드',
    subtitle: '당일 광선 정보와 Leave No Trace 실천을 한 묶음의 경량 도구로 정리해, 관람 계획과 보전 의식을 함께 돕습니다.',
