    waveLabel: '파고',
    seaLabel: '해상 상태',
    marineLoading: '해상 상태 불러오는 중...',
    marineFallback: '연안 해상 데이터를 불러오지 못했습니다. 조위와 승선 일정은 항만·해사·선사 공지를 우선하세요.',
    marineReady: '이 카드는 현장 참고용일 뿐 공식 조석표를 대체하지 않습니다. 강풍, 해무, 선편 조정 시에는 현장 안내를 우선하세요.',
    seaCalm: '잔잔함',
    seaModerate: '약한 물결',
    seaRough: '바람·파도 강함',
    riskLabel: '승선 위험 안내',
    riskShore: '해안 관람에 적합',
    riskConfirm: '선편 재확인 권장',
    riskCaution: '바람·파도 강해 접안 주의',
    lntEyebrow: 'Leave No Trace',
    lntTitle: '무흔 탐방 · 마이크로 서약',
    lntText: '현장에서 가장 중요한 세 가지 원칙을 읽고 가벼운 서약을 완료하세요. 정보는 업로드되지 않고 이 기기에만 저장됩니다.',
    progressTemplate: '원칙 {total}개 중 {count}개 확인',
    commitIdle: '서약 완료',
    commitDone: '서약 저장됨',
    statusIdle: '모든 원칙을 확인하면 로컬 서약을 완료할 수 있습니다.',
    statusDone: '이 해안을 더 낮은 간섭으로 대하려는 선택에 감사합니다.',
    principles: [
      { id: 'deck', label: '데크길과 기존 탐방로만 이용하기' },
      { id: 'trash', label: '쓰레기를 초지와 해안에 남기지 않기' },
      { id: 'quiet', label: '소음을 줄이고 난간을 넘지 않기' },
    ],
  },
}[lang] ?? {
  title: 'Field Science Notes',
  subtitle: 'A light toolkit that combines today’s light window with Leave No Trace practice.',
  principles: [],
};
---

<section
  id="field-notes"
  class="section-padding"
  style="background: var(--bg-secondary);"
  data-loading={field.loading}
  data-light-ready={field.lightReady}
  data-light-fallback={field.lightFallback}
  data-progress-template={field.progressTemplate}
  data-commit-idle={field.commitIdle}
  data-commit-done={field.commitDone}
  data-status-idle={field.statusIdle}
  data-status-done={field.statusDone}
  data-marine-loading={field.marineLoading}
  data-marine-ready={field.marineReady}
  data-marine-fallback={field.marineFallback}
  data-sea-calm={field.seaCalm}
  data-sea-moderate={field.seaModerate}
  data-sea-rough={field.seaRough}
  data-risk-shore={field.riskShore}
  data-risk-confirm={field.riskConfirm}
  data-risk-caution={field.riskCaution}
>
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{field.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{field.subtitle}</p>
    </div>

    <div class="grid xl:grid-cols-3 gap-6 items-start">
      <article class="rounded-3xl p-6 md:p-8 border" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
        <p class="text-xs uppercase tracking-[0.18em] mb-2" style="color: var(--text-muted);">{field.lightEyebrow}</p>
        <h3 class="font-semibold text-2xl mb-3" style="color: var(--text-primary);">{field.lightTitle}</h3>
        <p class="text-base leading-relaxed mb-6" style="color: var(--text-secondary);">{field.lightText}</p>

        <div class="grid sm:grid-cols-3 gap-3">
          <div class="rounded-2xl p-4 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
            <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.coordLabel}</p>
            <p class="text-base font-semibold" style="color: var(--text-primary);">34.7447° N, 128.6631° E</p>
          </div>
          <div class="rounded-2xl p-4 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
            <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.goldenLabel}</p>
            <p id="golden-hour-start" class="text-base font-semibold" style="color: var(--text-primary);">--:--</p>
          </div>
          <div class="rounded-2xl p-4 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
            <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.sunsetLabel}</p>
            <p id="field-sunset-time" class="text-base font-semibold" style="color: var(--text-primary);">--:--</p>
          </div>
        </div>

        <p id="field-light-note" class="mt-5 text-sm leading-relaxed" style="color: var(--text-secondary);">{field.loading}</p>
      </article>

      <article class="rounded-3xl p-6 md:p-8 border" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
        <p class="text-xs uppercase tracking-[0.18em] mb-2" style="color: var(--text-muted);">{field.marineEyebrow}</p>
        <h3 class="font-semibold text-2xl mb-3" style="color: var(--text-primary);">{field.marineTitle}</h3>
        <p class="text-base leading-relaxed mb-6" style="color: var(--text-secondary);">{field.marineText}</p>

        <div class="grid sm:grid-cols-3 xl:grid-cols-1 gap-3">
          <div class="rounded-2xl p-4 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
            <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.windLabel}</p>
            <p id="field-wind-speed" class="text-base font-semibold" style="color: var(--text-primary);">-- km/h</p>
          </div>
          <div class="rounded-2xl p-4 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
            <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.waveLabel}</p>
            <p id="field-wave-height" class="text-base font-semibold" style="color: var(--text-primary);">-- m</p>
          </div>
          <div class="rounded-2xl p-4 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
            <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.seaLabel}</p>
            <p id="field-sea-state" class="text-base font-semibold" style="color: var(--text-primary);">--</p>
          </div>
        </div>

        <div class="mt-4 rounded-2xl p-4 border" style="background: color-mix(in srgb, var(--accent) 8%, transparent); border-color: color-mix(in srgb, var(--accent) 22%, transparent);">
          <p class="text-xs uppercase tracking-[0.14em] mb-2" style="color: var(--text-muted);">{field.riskLabel}</p>
          <p id="field-boat-risk" class="text-base font-semibold" style="color: var(--text-primary);">--</p>
        </div>

        <p id="field-marine-note" class="mt-5 text-sm leading-relaxed" style="color: var(--text-secondary);">{field.marineLoading}</p>
      </article>

      <article class="rounded-3xl p-6 md:p-8 border" style="background: var(--bg-tertiary); border-color: var(--border-color);">
        <p class="text-xs uppercase tracking-[0.18em] mb-2" style="color: var(--text-muted);">{field.lntEyebrow}</p>
        <h3 class="font-semibold text-2xl mb-3" style="color: var(--text-primary);">{field.lntTitle}</h3>
        <p class="text-base leading-relaxed mb-5" style="color: var(--text-secondary);">{field.lntText}</p>

        <div class="science-meter" aria-hidden="true">
          <span id="science-meter-fill" class="science-meter-fill"></span>
        </div>
        <p id="science-progress" class="mt-3 text-sm" style="color: var(--text-secondary);"></p>

        <div class="mt-5 flex flex-wrap gap-3">
          {field.principles.map((item) => (
            <button type="button" class="science-chip" data-chip={item.id} aria-pressed="false">
              {item.label}
            </button>
          ))}
        </div>

        <div class="mt-6 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
          <button type="button" id="science-commit" class="science-pledge-button" disabled>
            {field.commitIdle}
          </button>
          <p id="science-status" class="text-sm leading-relaxed" style="color: var(--text-secondary);">{field.statusIdle}</p>
        </div>
      </article>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var section = document.getElementById('field-notes');
    if (!section) return;

    var sunsetEl = document.getElementById('field-sunset-time');
    var goldenEl = document.getElementById('golden-hour-start');
    var noteEl = document.getElementById('field-light-note');
    var windEl = document.getElementById('field-wind-speed');
    var waveEl = document.getElementById('field-wave-height');
    var seaEl = document.getElementById('field-sea-state');
    var riskEl = document.getElementById('field-boat-risk');
    var marineNoteEl = document.getElementById('field-marine-note');
    var progressEl = document.getElementById('science-progress');
    var statusEl = document.getElementById('science-status');
    var meterFill = document.getElementById('science-meter-fill');
    var commitBtn = document.getElementById('science-commit');
    var chips = Array.from(section.querySelectorAll('[data-chip]'));
    var storageKey = 'windyhill-lnt-v1';
    var state = { selected: [], committed: false };

    function formatTime(isoLike) {
      if (!isoLike || typeof isoLike !== 'string') return '--:--';
      var tIndex = isoLike.indexOf('T');
      if (tIndex === -1) return '--:--';
      return isoLike.slice(tIndex + 1, tIndex + 6) || '--:--';
    }

    function subtractMinutes(isoLike, minutes) {
      if (!isoLike) return '--:--';
      var date = new Date(isoLike);
      if (Number.isNaN(date.getTime())) return '--:--';
      date.setMinutes(date.getMinutes() - minutes);
      var hours = String(date.getHours()).padStart(2, '0');
      var mins = String(date.getMinutes()).padStart(2, '0');
      return hours + ':' + mins;
    }

    function seaStateLabel(waveHeight) {
      if (typeof waveHeight !== 'number') return '--';
      if (waveHeight <= 0.3) return section.getAttribute('data-sea-calm') || '';
      if (waveHeight <= 0.8) return section.getAttribute('data-sea-moderate') || '';
      return section.getAttribute('data-sea-rough') || '';
    }

    function boatRiskLabel(windSpeed, waveHeight) {
      if (typeof windSpeed !== 'number' && typeof waveHeight !== 'number') return '--';
      if ((typeof waveHeight === 'number' && waveHeight > 0.8) || (typeof windSpeed === 'number' && windSpeed > 28)) {
        return section.getAttribute('data-risk-caution') || '';
      }
      if ((typeof waveHeight === 'number' && waveHeight > 0.3) || (typeof windSpeed === 'number' && windSpeed > 16)) {
        return section.getAttribute('data-risk-confirm') || '';
      }
      return section.getAttribute('data-risk-shore') || '';
    }

    function progressText(count, total) {
      var tpl = section.getAttribute('data-progress-template') || '{count}/{total}';
      return tpl.replace('{count}', String(count)).replace('{total}', String(total));
    }

    function setChipState(chip, active) {
      chip.classList.toggle('is-active', active);
      chip.setAttribute('aria-pressed', active ? 'true' : 'false');
    }

    function renderPledge() {
      var total = chips.length;
      var count = state.selected.length;
      chips.forEach(function (chip) {
        setChipState(chip, state.selected.indexOf(chip.getAttribute('data-chip')) !== -1);
      });
      if (progressEl) progressEl.textContent = progressText(count, total);
      if (meterFill) meterFill.style.width = total ? String((count / total) * 100) + '%' : '0%';
      if (commitBtn) {
        commitBtn.disabled = count !== total;
        commitBtn.textContent = state.committed
          ? (section.getAttribute('data-commit-done') || '')
          : (section.getAttribute('data-commit-idle') || '');
        commitBtn.classList.toggle('is-complete', state.committed);
      }
      if (statusEl) {
        statusEl.textContent = state.committed
          ? (section.getAttribute('data-status-done') || '')
          : (section.getAttribute('data-status-idle') || '');
      }
    }

    function persist() {
      try {
        localStorage.setItem(storageKey, JSON.stringify(state));
      } catch (e) {}
    }

    function restore() {
      try {
        var raw = localStorage.getItem(storageKey);
        if (!raw) return;
        var parsed = JSON.parse(raw);
        if (parsed && Array.isArray(parsed.selected)) {
          state.selected = parsed.selected;
          state.committed = !!parsed.committed;
        }
      } catch (e) {}
    }

    chips.forEach(function (chip) {
      chip.addEventListener('click', function () {
        var id = chip.getAttribute('data-chip');
        if (!id) return;
        if (state.selected.indexOf(id) !== -1) {
          state.selected = state.selected.filter(function (item) { return item !== id; });
          state.committed = false;
        } else {
          state.selected = state.selected.concat(id);
        }
        renderPledge();
        persist();
      });
    });

    if (commitBtn) {
      commitBtn.addEventListener('click', function () {
        if (state.selected.length !== chips.length) return;
        state.committed = true;
        renderPledge();
        persist();
      });
    }

    restore();
    renderPledge();

    if (noteEl) noteEl.textContent = section.getAttribute('data-loading') || '';
    if (marineNoteEl) marineNoteEl.textContent = section.getAttribute('data-marine-loading') || '';

    Promise.all([
      fetch('https://api.open-meteo.com/v1/forecast?latitude=34.7447&longitude=128.6631&daily=sunset&current=wind_speed_10m&timezone=Asia/Seoul', { cache: 'no-store' }),
      fetch('https://marine-api.open-meteo.com/v1/marine?latitude=34.7447&longitude=128.6631&current=wave_height&timezone=Asia/Seoul', { cache: 'no-store' }),
    ])
      .then(function (responses) {
        return Promise.all(responses.map(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.json();
        }));
      })
      .then(function (payload) {
        var weatherData = payload[0] || {};
        var marineData = payload[1] || {};
        var sunset = weatherData && weatherData.daily && weatherData.daily.sunset ? weatherData.daily.sunset[0] : '';
        var wind = weatherData && weatherData.current ? weatherData.current.wind_speed_10m : undefined;
        var wave = marineData && marineData.current ? marineData.current.wave_height : undefined;

        if (sunsetEl) sunsetEl.textContent = formatTime(sunset);
        if (goldenEl) goldenEl.textContent = subtractMinutes(sunset, 60);
        if (noteEl) noteEl.textContent = section.getAttribute('data-light-ready') || '';
        if (windEl) windEl.textContent = typeof wind === 'number' ? Math.round(wind) + ' km/h' : '-- km/h';
        if (waveEl) waveEl.textContent = typeof wave === 'number' ? wave.toFixed(1) + ' m' : '-- m';
        if (seaEl) seaEl.textContent = seaStateLabel(wave);
        if (riskEl) riskEl.textContent = boatRiskLabel(wind, wave);
        if (marineNoteEl) marineNoteEl.textContent = section.getAttribute('data-marine-ready') || '';
      })
      .catch(function () {
        if (noteEl) noteEl.textContent = section.getAttribute('data-light-fallback') || '';
        if (riskEl) riskEl.textContent = '--';
        if (marineNoteEl) marineNoteEl.textContent = section.getAttribute('data-marine-fallback') || '';
      });
  })();
</script>

<style>
  .science-meter {
    width: 100%;
    height: 0.5rem;
    border-radius: 999px;
    overflow: hidden;
    background: color-mix(in srgb, var(--accent) 10%, var(--bg-secondary));
  }
  .science-meter-fill {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: inherit;
    background: var(--accent);
    transition: width 0.2s ease;
  }
  .science-chip {
    border: 1px solid var(--border-color);
    border-radius: 999px;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    line-height: 1.4;
    text-align: left;
    color: var(--text-primary);
    background: var(--card-bg);
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }
  .science-chip:hover {
    transform: translateY(-1px);
  }
  .science-chip.is-active {
    color: #fff;
    border-color: transparent;
    background: var(--accent);
  }
  .science-pledge-button {
    border: none;
    border-radius: 999px;
    padding: 0.9rem 1.2rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.15s ease, background 0.2s ease;
  }
  .science-pledge-button:hover:not(:disabled) {
    transform: translateY(-1px);
  }
  .science-pledge-button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }
  .science-pledge-button.is-complete {
    background: var(--color-nature-600);
  }
</style>
