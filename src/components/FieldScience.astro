---
import { getI18n } from '../i18n/ui';

const { lang } = getI18n(Astro.url);
const field = {
  zh: {
    title: '现场科学卡片',
    subtitle: '把当天的光线窗口与无痕山林原则合并成一组轻量工具，既方便规划拍摄，也保持这片海岸的教育属性。',
