    lntEyebrow: 'Leave No Trace',
    lntTitle: '無痕の丘陵・ミクロ誓約',
    lntText: '現地で重要な三つの原則を読み、軽い誓約を完了します。情報は送信されず、この端末にだけ保存されます。',
    progressTemplate: '{total} 項目中 {count} 項目を確認',
    commitIdle: '誓約を完了',
    commitDone: '誓約を保存済み',
