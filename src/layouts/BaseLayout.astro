---
import '../styles/global.css';
import Header from '../components/Header.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, buildAlternates, htmlLangAttr, getI18n } from '../i18n/ui';
import { ogLocale } from '../config';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const htmlLang = htmlLangAttr(lang);
const alts = buildAlternates(path);
const canonical = alts[lang] ?? alts.zh;
const { messages } = getI18n(Astro.url);
const imageUrl = 'https://windyhillkorea.com/gallery/windy-hill-1.jpg';
const placeId = `${canonical}#place`;
const attractionId = `${canonical}#attraction`;
const pageId = `${canonical}#webpage`;
const imageId = `${canonical}#primaryimage`;
const authorityId = 'https://www.knps.or.kr/#organization';
const officialReferences = {
  knps: 'https://english.knps.or.kr/Knp/Hallyeohaesang/Intro/Introduction.aspx?MenuNum=1&Submenu=Npp',
  geoje: 'https://tour.geoje.go.kr/index.geoje?menuCd=DOM_000008902001000000',
  maps: 'https://maps.app.goo.gl/Vh7pZjbLwYiGonFd8',
};
const touristAttractionLd = {
  '@type': 'TouristAttraction',
  '@id': attractionId,
  name: messages.meta.title,
  alternateName: ['Windy Hill', '바람의 언덕', '风之丘'],
  description: messages.meta.description,
  url: canonical,
  isAccessibleForFree: true,
  publicAccess: true,
  image: { '@id': imageId },
  mainEntityOfPage: { '@id': pageId },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Galgot-ri 14-47, Nambu-myeon',
    addressLocality: 'Geoje-si',
    addressRegion: 'Gyeongsangnam-do',
    postalCode: '53261',
    addressCountry: 'KR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 34.7447,
    longitude: 128.6631,
  },
  containedInPlace: { '@id': placeId },
  touristType: ['Independent travellers', 'Family visitors', 'Landscape photographers'],
  keywords: [
    'Windy Hill',
    '바람의 언덕',
    '风之丘',
    'Geoje',
    'Hallyeohaesang National Park',
    'Marine terrace',
    'Coastal meadow',
  ],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Coordinates', value: '34.7447, 128.6631' },
    { '@type': 'PropertyValue', name: 'Conservation status', value: 'Hallyeohaesang National Park, District 4' },
    { '@type': 'PropertyValue', name: 'Landform', value: 'Marine terrace / Coastal meadow' },
    { '@type': 'PropertyValue', name: 'Dominant vegetation', value: 'Imperata cylindrica coastal grassland' },
    { '@type': 'PropertyValue', name: 'Managing authority', value: 'Korea National Park Service and Geoje City' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.2',
    reviewCount: '11454',
  },
  sameAs: [officialReferences.maps, officialReferences.knps, officialReferences.geoje],
};
const breadcrumbLd = (() => {
  const bc = messages.breadcrumb;
  return {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: bc.home, item: `https://windyhillkorea.com/${lang}` },
      { '@type': 'ListItem', position: 2, name: bc.geoje, item: `https://windyhillkorea.com/${lang}#overview` },
      { '@type': 'ListItem', position: 3, name: bc.nambu, item: `https://windyhillkorea.com/${lang}#transport` },
      { '@type': 'ListItem', position: 4, name: bc.current, item: canonical },
    ],
  };
})();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': pageId,
      url: canonical,
      name: title,
      description,
      inLanguage: htmlLang,
      primaryImageOfPage: { '@id': imageId },
      about: { '@id': attractionId },
      isPartOf: {
        '@type': 'WebSite',
        '@id': 'https://windyhillkorea.com/#website',
        url: 'https://windyhillkorea.com/',
        name: 'Windy Hill Korea',
      },
    },
    {
      '@type': 'ImageObject',
      '@id': imageId,
      contentUrl: imageUrl,
      url: imageUrl,
      caption: 'Windy Hill windmill and coastal meadow in Geoje',
    },
    {
      '@type': 'Place',
      '@id': placeId,
      name: 'Windy Hill coastal hill, Geoje',
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 34.7447,
        longitude: 128.6631,
      },
      containedInPlace: {
        '@type': 'AdministrativeArea',
        name: 'Hallyeohaesang National Park, District 4',
      },
    },
    {
      '@type': 'Organization',
      '@id': authorityId,
      name: 'Korea National Park Service',
      sameAs: officialReferences.knps,
      url: 'https://www.knps.or.kr/',
    },
    {
      ...touristAttractionLd,
      provider: { '@id': authorityId },
      subjectOf: [
        { '@type': 'CreativeWork', url: officialReferences.knps, name: 'KNPS reference' },
        { '@type': 'CreativeWork', url: officialReferences.geoje, name: 'Geoje tourism reference' },
      ],
    },
    breadcrumbLd,
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preload" as="image" href="/gallery/windy-hill-1.jpg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={alts.zh} />
    <link rel="alternate" hreflang="en" href={alts.en} />
    <link rel="alternate" hreflang="ja" href={alts.ja} />
    <link rel="alternate" hreflang="ko" href={alts.ko} />
    <link rel="alternate" hreflang="x-default" href={alts.xDefault} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale[lang] ?? lang} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <Header />
    <NoticeBanner />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
